NODE_ENV=development
PORT=5000
CLIENT_PORT=5173
MONGO_URI=mongodb://mongo:27017/incidentflow
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
CLIENT_ORIGIN=http://localhost:5173
LOG_LEVEL=info
FEATURE_INCIDENTS=true
FEATURE_BUS_TRACKING=true
FEATURE_AI_CORRECTION=true
USE_IN_MEMORY_DB=false
BUS_UPDATE_INTERVAL_MS=5000
SLA_LOW_HOURS=24
SLA_MEDIUM_HOURS=12
SLA_HIGH_HOURS=4
SLA_CRITICAL_HOURS=1
ACTIVE_COLOR=blue
BACKEND_BLUE_PORT=5001
BACKEND_GREEN_PORT=5002
FRONTEND_BLUE_PORT=8081
FRONTEND_GREEN_PORT=8082
PROXY_PORT=8080
DOCKER_REGISTRY=docker.io/yourname
BACKEND_IMAGE=incidentflow-plus-backend
FRONTEND_IMAGE=incidentflow-plus-frontend
AI_PROVIDER=local
OPENAI_API_KEY=
